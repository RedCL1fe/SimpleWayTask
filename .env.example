# --- База Данных (PostgreSQL) ---
POSTGRES_DB=price_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_db_password_here

# --- Бэкенд (Django) ---
# Секретный ключ для криптографии (сгенерируйте уникальный длинный ключ)
DJANGO_SECRET_KEY=django-insecure-example-key-replace-it-in-production
# Режим отладки. Обязательно False на продакшене!
DEBUG=True
# Разрешенные хосты (через запятую), например: localhost,127.0.0.1,yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- Очереди и Брокер (Redis & Celery) ---
REDIS_PASSWORD=your_secure_redis_password_here
# В Celery URL необходимо подставить пароль из REDIS_PASSWORD
CELERY_BROKER_URL=redis://:your_secure_redis_password_here@redis:6379/0
CELERY_RESULT_BACKEND=redis://:your_secure_redis_password_here@redis:6379/0

# --- Настройки AI-сопоставления (Опционально) ---
MATCH_THRESHOLD=75
